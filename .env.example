# Copy this file to .env and fill in values from your hosting dashboard.

# Required
DISCORD_TOKEN=
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DATABASE=
XAI_API_KEY=

# Optional: guild ID for instant slash-command sync on startup.
# Without this, commands sync globally (can take up to ~1 hour to appear).
# DISCORD_GUILD_ID=

# Optional: DINK awarded per successful /1st claim (default 1)
DINK_MINT_AMOUNT=1

# Nightly sentiment (cheap Grok via XAI_API_KEY — scores messages missing from message_sentiment)
# GROK_SENTIMENT_MODEL=grok-4.3
# Optional cap per run (newest unscored first; useful while catching up historical holes)
# SENTIMENT_NIGHTLY_LIMIT=500
